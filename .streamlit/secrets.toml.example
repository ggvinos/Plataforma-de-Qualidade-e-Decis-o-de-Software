# ================================================================================
# EXEMPLO DE SECRETS - COPIE PARA secrets.toml E PREENCHA
# ================================================================================
# 1. Copie este arquivo para: .streamlit/secrets.toml
# 2. Preencha com suas credenciais reais
# 3. O arquivo secrets.toml está no .gitignore (não será commitado)
#
# Para Streamlit Cloud:
# - Vá em App Settings > Secrets
# - Cole o conteúdo do secrets.toml
# ================================================================================

[jira]
base_url = "https://SEU-WORKSPACE.atlassian.net"
email = "seu-email@empresa.com"
token = "SEU_TOKEN_DO_JIRA"

[auth]
# Lista de emails autorizados (separados por vírgula)
emails_autorizados = "email1@empresa.com,email2@empresa.com"
